# Consumer container-ops entry (just). The layered entry (ADR-00000010):
# symlinked into the consumer as <repo>/script/justfile, with
# <repo>/justfile -> script/justfile, so users run `just <verb> [args...]`
# from the repo root.
#
# Import/mod paths resolve relative to the SYMLINK location (the repo root),
# not this file's real .base/downstream/ location -- so `script/...` paths
# below are repo-root-relative. docker recipes are imported TOP-LEVEL
# (`just build`); repo-local command groups come in via the repo-owned
# registry script/local/justfile.local (each group a `mod?` line ->
# `just <group> <recipe>`). The ci / cd namespaces are wired in by #634.

import 'script/docker/justfile.docker'

# `just template new <name>` scaffolds a repo-local command group under
# script/local/ and registers it. Bare `just template` prints help.
mod? template 'script/template/justfile.template'

# Repo-local command groups. script/local/justfile.local is REPO-OWNED
# (seeded once by init.sh, committed, never clobbered by a subtree upgrade);
# `import?` keeps a missing/empty registry from erroring. `mod?` lines in it
# register each group (`just template new <name>` appends them, #633).
import? 'script/local/justfile.local'

# Default: list available recipes (replaces `make help`).
default:
    @just --list
