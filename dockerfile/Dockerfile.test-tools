# Dockerfile.test-tools - Pre-built test tools for Docker container repos
#
# Contains: ShellCheck, Hadolint, Bats (with bats-support + bats-assert +
# bats-mock), kcov (coverage)
#
# Usage:
#   docker build -t test-tools:local -f .base/dockerfile/Dockerfile.test-tools .
#   Then in repo Dockerfile:
#     COPY --from=test-tools:local /usr/local/bin/shellcheck /usr/local/bin/shellcheck

ARG BATS_VERSION=1.13.0
ARG ALPINE_VERSION=3.21
ARG KCOV_VERSION=v43

FROM bats/bats:${BATS_VERSION} AS bats-src

FROM alpine:${ALPINE_VERSION} AS bats-extensions
RUN apk add --no-cache git && \
    git clone --depth 1 -b v0.3.0 \
        https://github.com/bats-core/bats-support /bats/bats-support && \
    git clone --depth 1 -b v2.1.0 \
        https://github.com/bats-core/bats-assert  /bats/bats-assert && \
    git clone --depth 1 -b v1.2.5 \
        https://github.com/jasonkarns/bats-mock   /bats/bats-mock

FROM alpine:${ALPINE_VERSION} AS lint-tools
# TARGETARCH is auto-populated by BuildKit (docker 23+) with "amd64" /
# "arm64" / etc. Do NOT set a default — a default value shadows
# BuildKit's auto-inject (moby/buildkit#3403), which caused every
# multi-arch build of this file to fall back to amd64 and ship
# x86_64 shellcheck / hadolint inside the arm64 image variant
# (visible symptom: `shellcheck: Exec format error` on arm64 downstream
# CI). If invoked outside BuildKit, pass `--build-arg TARGETARCH=<arch>`.
ARG TARGETARCH
# hadolint ignore=DL4006
RUN apk add --no-cache curl xz && \
    case "${TARGETARCH}" in \
      amd64)  sc_arch="x86_64";  hd_arch="x86_64" ;; \
      arm64)  sc_arch="aarch64"; hd_arch="arm64"  ;; \
      *) echo "Unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac && \
    curl -fsSL --retry 5 --retry-all-errors --retry-delay 3 \
        "https://github.com/koalaman/shellcheck/releases/download/v0.10.0/shellcheck-v0.10.0.linux.${sc_arch}.tar.xz" \
        | tar -xJ -C /tmp && \
    mv "/tmp/shellcheck-v0.10.0/shellcheck" /usr/local/bin/shellcheck && \
    curl -fsSL --retry 5 --retry-all-errors --retry-delay 3 -o /usr/local/bin/hadolint \
        "https://github.com/hadolint/hadolint/releases/download/v2.12.0/hadolint-Linux-${hd_arch}" && \
    chmod +x /usr/local/bin/hadolint

# kcov is not packaged in any Alpine repository (main / community /
# edge-testing all lack it -- verified), so it cannot be `apk add`ed like
# the other tools. Compile it from source in a throwaway builder stage and
# COPY only the binary into the final image; the final stage `apk add`s
# just the runtime shared libs kcov links against (libstdc++ / libcurl /
# libdw / libelf / zlib / libgcc), not the build toolchain. This keeps the
# coverage path on the SAME pre-baked Alpine image as the rest of the
# self-test suite (one image, one pull) instead of the old debian
# kcov/kcov service that apt-installed ~24 packages on every coverage shard
# of every PR. kcov-on-musl was spiked for accuracy + stability: line-rate
# and per-file covered counts matched the debian kcov baseline within <0.1%
# (codecov threshold is 1%) and were bit-stable across repeated runs.
FROM alpine:${ALPINE_VERSION} AS kcov-builder
ARG KCOV_VERSION
RUN apk add --no-cache \
        cmake make g++ binutils-dev curl-dev elfutils-dev libdwarf-dev \
        zlib-dev python3 git && \
    git clone --depth 1 -b "${KCOV_VERSION}" \
        https://github.com/SimonKagstrom/kcov /tmp/kcov && \
    cmake -S /tmp/kcov -B /tmp/kcov/build && \
    make -C /tmp/kcov/build -j"$(nproc)" && \
    make -C /tmp/kcov/build install

# Final stage: bash + bats + shellcheck + hadolint + bats-{support,assert,mock}
# + parallel + git + ca-certificates + kcov.
# bash is required because /opt/bats/bin/bats is a `#!/usr/bin/env bash` script
# and alpine:latest only ships busybox ash. The /usr/local/bin/bats symlink
# exposes bats on PATH (the upstream bats/bats:latest puts it there but the
# symlink is not under /opt/bats so it is not picked up by the COPY above).
# parallel (#168): bats --jobs N delegates to GNU parallel; without it bats
# falls back to serial. test.sh tolerates missing parallel for older images,
# but baking it in keeps the fast CI loop fast.
# git + git-subtree + ca-certificates (#168): the test suite
# (upgrade_spec.bats, init_new_repo_spec.bats,
# fresh_clone_portability_spec.bats) builds fake subtree repos with
# `git -C <dir> init/commit` and exercises `git subtree pull/add` paths
# end-to-end. On debian `git-subtree` is bundled in the `git` package;
# alpine ships it as a separate `git-subtree` package. ca-certificates
# is needed by the few specs that hit GitHub over HTTPS.
# grep + coreutils (#168): downstream scripts and several specs rely
# on GNU-only flags (`grep -P` for PCRE, GNU-format `sha256sum` output)
# that busybox's defaults do not provide. Installing the GNU packages
# overrides busybox's symlinks so init.sh / setup.sh / setup_drift
# helpers behave the same on alpine as on the previous kcov/kcov
# (debian) runner.
# just (#175): integration tests exercise `just upgrade-check` end-to-end
# to verify the downstream justfile recipe wraps upgrade.sh exit 1 (update
# available) as success. `just` is the single runner (the Makefile / make
# are retired), so install it explicitly — alpine provides no `just`.
# docker-cli + docker-cli-buildx (#249): the system test suite
# (test/bats/system/*.bats) drives `docker buildx build --target
# runtime-test ...` against synthesized fixtures to assert the runtime
# smoke gate actually gates. Only active when the ci-system
# compose service is invoked (it mounts the host docker.sock); the
# default `ci` service ignores docker even when CLI is present.
FROM alpine:${ALPINE_VERSION}
# mawk + gawk alongside the default busybox awk so the issueref awk
# program is exercised under all three engines by its portability unit
# test (issueref_lint_spec.bats). This closes a local==CI blind spot in
# the issueref match() greediness (a mawk-only regression) by running the
# awk program under mawk and gawk in-image rather than relying on a
# separate runner to surface it.
# libstdc++ / libcurl / libdw / libelf / zlib / libgcc are the runtime
# shared libs the source-built kcov binary (copied below) links against;
# they are the runtime counterparts of the -dev packages used in the
# kcov-builder stage. Without them kcov would fail to load at runtime.
# docker-cli-compose + xz: the field-deploy system test
# (test/bats/system/deploy_bundle_e2e_spec.bats) runs the generated
# deploy.sh up (real `docker compose up -d`) and unxz's the bundled
# image.tar.xz; the generator itself xz-compresses the saved image.
RUN apk add --no-cache bash parallel git git-subtree ca-certificates grep coreutils just docker-cli docker-cli-buildx docker-cli-compose xz mawk gawk \
        libstdc++ libcurl libdw libelf zlib libgcc
COPY --from=bats-src /opt/bats /opt/bats
COPY --from=bats-src /usr/lib/bats /usr/lib/bats
COPY --from=bats-extensions /bats /usr/lib/bats
COPY --from=lint-tools /usr/local/bin/shellcheck /usr/local/bin/
COPY --from=lint-tools /usr/local/bin/hadolint /usr/local/bin/
COPY --from=kcov-builder /usr/local/bin/kcov /usr/local/bin/kcov
RUN ln -s /opt/bats/bin/bats /usr/local/bin/bats
